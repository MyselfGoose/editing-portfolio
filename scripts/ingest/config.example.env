# Goose Productions — Drive → Mux Ingest configuration
# Copy to config.env and fill in values: cp config.example.env config.env

# ── Mux API (dashboard.mux.com → Settings → API Access Tokens) ──
MUX_TOKEN_ID=your_token_id
MUX_TOKEN_SECRET=your_token_secret
MUX_API_BASE=https://api.mux.com

# ── Google Drive (via rclone) ──
RCLONE_REMOTE=gdrive
RCLONE_FOLDER=Portfolio/Masters
DRIVE_FOLDER_ID=

# ── Ingest defaults (match docs/video-ingest.md) ──
MUX_PLAYBACK_POLICY=public
MUX_ENCODING_TIER=smart
MUX_NORMALIZE_AUDIO=true
MUX_MP4_SUPPORT=none
MUX_MAX_RESOLUTION_TIER=1080p

# ── Paths (relative to scripts/ingest/) ──
PROJECTS_TS_PATH=../../frontend/src/data/projects.ts
MANIFEST_PATH=./ingest-manifest.json
STATE_DIR=./state
TMP_DIR=./tmp
LOG_DIR=./logs
OUTPUT_DIR=./output

# ── Behavior ──
DEFAULT_POSTER_PERCENT=25
DEFAULT_PREVIEW_SECONDS=4
PREVIEW_END_OFFSET=0
EXCLUDE_GLOBS=draft-*,_*,*.srt,*.vtt,*.jpg,*.png
MIN_FREE_DISK_GB=10
MUX_POLL_INTERVAL_SEC=5
MUX_POLL_MAX_WAIT_SEC=7200
CONFIRM_BATCH_GB=20
CORS_ORIGIN=*
